# -----------------------------------------------------------------------------
# VoiceOps — copy to .env and fill in values. Never commit .env to git.
# -----------------------------------------------------------------------------

# Frontend (Vite) — backend API URL for browser requests
VITE_API_BASE_URL=http://127.0.0.1:8000

# Backend — required
OPENAI_API_KEY=

# Backend — optional; when unset, defaults to /data/uploads and /data (Docker/Railway).
# For local dev, set to e.g. voiceops/backend/uploads and voiceops/backend/data
UPLOAD_DIR=
DATA_DIR=

# Backend — CORS: add deployed frontend origin(s), comma-separated (e.g. Vercel URL)
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# Backend — optional; JSON object of model names (transcription, insights, chat, embeddings)
# MODEL_NAMES={"transcription":"base","insights":"gpt-4o-mini","chat":"gpt-4o-mini","embeddings":"text-embedding-3-small"}
