# -----------------------------------------------------------------------------
# VoiceOps — copy to .env and fill in values. Never commit .env to git.
# -----------------------------------------------------------------------------

# Frontend (Vite) — backend API URL for browser requests
VITE_API_BASE_URL=http://127.0.0.1:8000

# Backend — required
OPENAI_API_KEY=

# Backend — optional; defaults to backend/uploads and backend/data if unset
# Production example:
# UPLOAD_DIR=/var/data/uploads
# DATA_DIR=/var/data
UPLOAD_DIR=
DATA_DIR=

# Backend — optional; JSON object of model names (transcription, insights, chat, embeddings)
# MODEL_NAMES={"transcription":"base","insights":"gpt-4o-mini","chat":"gpt-4o-mini","embeddings":"text-embedding-3-small"}
